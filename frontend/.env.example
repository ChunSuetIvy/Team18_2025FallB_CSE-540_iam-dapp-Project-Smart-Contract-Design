# Target network for the frontend.
# Use POLYGON_AMOY for Polygon Amoy or HARDHAT_LOCAL for local Hardhat testing.
VITE_TARGET_NETWORK=HARDHAT_LOCAL

# Smart Contract Addresses
# For local Hardhat testing, use your deployed local contract addresses.
# For Polygon Amoy, use your deployed Amoy contract addresses.
VITE_DID_REGISTRY_ADDRESS=0x
VITE_CREDENTIAL_ISSUER_ADDRESS=0x
VITE_ACCESS_CONTROL_ADDRESS=0x

# Local Hardhat RPC endpoint (used when VITE_TARGET_NETWORK=HARDHAT_LOCAL)
VITE_HARDHAT_RPC=http://127.0.0.1:8545

# Optional: Custom RPC endpoint for Polygon Amoy
# VITE_POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
